# Required
ANTHROPIC_API_KEY=sk-ant-...

# Twitter
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Scanning
SCAN_INTERVAL_MS=900000
MAX_TWEETS_PER_CYCLE=500
SENTIMENT_HISTORY_HOURS=24

# Narrative model
MIN_ENGAGEMENT_SCORE=50
MIN_INFLUENCER_FOLLOWERS=10000
AUTHOR_CREDIBILITY_WEIGHT=0.35
SOURCE_DIVERSITY_WEIGHT=0.30
PERSISTENCE_WEIGHT=0.20
CONTRADICTION_PENALTY_WEIGHT=0.15
NARRATIVE_HALF_LIFE_MINUTES=180   # shorten this if CT is recycling the same headline too quickly
CONTESTED_CLUSTER_THRESHOLD=0.33

# Tokens
TRACKED_TOKENS=SOL,JTO,BONK,WIF,PENGU,JUP,RAY

# Model
CLAUDE_MODEL=claude-sonnet-4-5-20251001
